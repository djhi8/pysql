a) Create a stored procedure that accepts two numbers and prints their sum
CREATE OR REPLACE PROCEDURE calc_sum (
    num1 IN NUMBER,
    num2 IN NUMBER
)
IS
    total NUMBER;
BEGIN
    total := num1 + num2;
    DBMS_OUTPUT.PUT_LINE('Sum = ' || total);
END;
/
Execute the procedure
BEGIN
    calc_sum(10, 5);
END;
/



b) Alter the procedure to also calculate the difference.
PL/SQL, we recreate the procedure using CREATE OR REPLACE.
CREATE OR REPLACE PROCEDURE calc_sum (
    num1 IN NUMBER,
    num2 IN NUMBER
)
IS
    total NUMBER;
    diff  NUMBER;
BEGIN
    total := num1 + num2;
    diff  := num1 - num2;

    DBMS_OUTPUT.PUT_LINE('Sum = ' || total);
    DBMS_OUTPUT.PUT_LINE('Difference = ' || diff);
END;
/
Execute the altered procedure
BEGIN
    calc_sum(20, 8);
END;
/

