A)	Use a record variable in a loop to display data from a table.
              Step 1: Create the Table First
Run this before your PL/SQL block:
CREATE TABLE employee (
    emp_id   NUMBER,
    emp_name VARCHAR2(50),
    salary   NUMBER(10,2)
);

Step 2 Insert Sample Data
INSERT INTO employee VALUES (101, 'Alice', 45000);
INSERT INTO employee VALUES (102, 'Bob', 55000);
INSERT INTO employee VALUES (103, 'Charlie', 60000);

COMMIT;

 Step 3 code
SET SERVEROUTPUT ON;

DECLARE
    CURSOR emp_cursor IS 
        SELECT emp_id, emp_name, salary FROM employee;

BEGIN
    FOR emp_rec IN emp_cursor LOOP
        DBMS_OUTPUT.PUT_LINE('ID: ' || emp_rec.emp_id ||
                             ', Name: ' || emp_rec.emp_name ||
                             ', Salary: ' || emp_rec.salary);
    END LOOP;
END;
/

B)	Create a table of records using nested collections
   DECLARE
    -- Define record type
    TYPE emp_record IS RECORD (
        emp_id   NUMBER,
        emp_name VARCHAR2(50),
        salary   NUMBER(10,2)
    );

    -- Define table type (nested collection) of records
    TYPE emp_table IS TABLE OF emp_record;

    emp_list emp_table := emp_table();  -- Initialize collection

BEGIN
    -- Add records to collection
    emp_list.EXTEND;
    emp_list(1).emp_id := 101;
    emp_list(1).emp_name := 'Alice';
    emp_list(1).salary := 45000;

    emp_list.EXTEND;
    emp_list(2).emp_id := 102;
    emp_list(2).emp_name := 'Bob';
    emp_list(2).salary := 55000;

    -- Display records
    FOR i IN 1 .. emp_list.COUNT LOOP
        DBMS_OUTPUT.PUT_LINE('ID: ' || emp_list(i).emp_id ||
                             ', Name: ' || emp_list(i).emp_name ||
                             ', Salary: ' || emp_list(i).salary);
    END LOOP;
END;
/
