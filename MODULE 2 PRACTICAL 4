a)	Use Native Dynamic SQL (EXECUTE IMMEDIATE) to create a table at runtime.
DECLARE
    v_sql VARCHAR2(200);
BEGIN
    -- SQL statement to create table
    v_sql := 'CREATE TABLE student_dynamic (
                student_id NUMBER,
                student_name VARCHAR2(50),
                marks NUMBER
              )';

    -- Execute dynamic SQL
    EXECUTE IMMEDIATE v_sql;

    DBMS_OUTPUT.PUT_LINE('Table created successfully.');

EXCEPTION
    WHEN OTHERS THEN
        DBMS_OUTPUT.PUT_LINE('Error: ' || SQLERRM);
END;
/








PRACTICAL 5
a)	Use the DBMS_SQL package to parse and execute a DML statement dynamically
CREATE TABLE employee_demo (
    emp_id NUMBER,
    emp_name VARCHAR2(50),
    salary NUMBER
);
SET SERVEROUTPUT ON;

DECLARE
    v_cursor INTEGER;
    v_sql    VARCHAR2(200);
    v_rows   INTEGER;
BEGIN
    -- Open cursor
    v_cursor := DBMS_SQL.OPEN_CURSOR;

    -- Dynamic SQL statement (DML)
    v_sql := 'INSERT INTO employee_demo VALUES (1, ''Shreya'', 50000)';

    -- Parse SQL statement
    DBMS_SQL.PARSE(v_cursor, v_sql, DBMS_SQL.NATIVE);

    -- Execute statement
    v_rows := DBMS_SQL.EXECUTE(v_cursor);

    DBMS_OUTPUT.PUT_LINE('Rows inserted: ' || v_rows);

    -- Close cursor
    DBMS_SQL.CLOSE_CURSOR(v_cursor);

EXCEPTION
    WHEN OTHERS THEN
        IF DBMS_SQL.IS_OPEN(v_cursor) THEN
            DBMS_SQL.CLOSE_CURSOR(v_cursor);
        END IF;
        DBMS_OUTPUT.PUT_LINE('Error: ' || SQLERRM);
END;
/





